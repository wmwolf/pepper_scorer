---
// src/pages/account.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPath } from '../lib/path-utils';
---

<BaseLayout title="Account Management">
  <div class="max-w-4xl mx-auto">
    <!-- Loading State -->
    <div id="auth-loading" class="text-center py-12">
      <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600 mx-auto mb-4"></div>
      <p class="text-gray-600">Loading account...</p>
    </div>

    <!-- Authentication Required Message -->
    <div id="auth-required" class="text-center py-12 hidden">
      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6">
        <h2 class="text-xl font-semibold text-yellow-800 mb-4">Authentication Required</h2>
        <p class="text-yellow-700 mb-4">You must be signed in to access your account settings.</p>
        <a href={getPath('')} class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to Home
        </a>
      </div>
    </div>

    <!-- Account Management Content -->
    <div id="account-content" class="hidden space-y-8">
      <!-- User Profile Section -->
      <div class="bg-white shadow-sm rounded-lg p-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Profile Settings</h2>

        <div class="flex items-start space-x-6">
          <!-- User Avatar -->
          <div class="flex-shrink-0">
            <img id="profile-photo" class="w-20 h-20 rounded-full border-2 border-gray-200" alt="Profile photo" />
          </div>

          <!-- Profile Info -->
          <div class="flex-1 space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <p id="profile-email" class="text-gray-600 bg-gray-50 px-3 py-2 rounded-md">Loading...</p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
              <p id="profile-username" class="text-gray-600 bg-gray-50 px-3 py-2 rounded-md">Loading...</p>
            </div>

            <div>
              <label for="display-name-input" class="block text-sm font-medium text-gray-700 mb-1">Display Name</label>
              <div class="space-y-2">
                <div class="flex space-x-2">
                  <input
                    type="text"
                    id="display-name-input"
                    class="flex-1 border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                    placeholder="Enter your display name"
                  />
                  <button
                    id="save-display-name-btn"
                    class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors disabled:bg-gray-300 disabled:cursor-not-allowed"
                    disabled
                  >
                    Save
                  </button>
                </div>
                <button
                  id="reset-display-name-btn"
                  class="text-sm text-gray-600 hover:text-blue-600 underline transition-colors"
                >
                  Reset to Google account name
                </button>
              </div>
              <p class="text-sm text-gray-500 mt-1">This is how your name appears to other players.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Pending Invitations (Phase 9) -->
      <div id="invitations-card" class="bg-white shadow-sm rounded-lg p-6 hidden">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Game Invitations</h2>
        <div id="invitations-list" class="space-y-4">
          <!-- Pending invitations will be populated here -->
        </div>
      </div>

      <!-- Active Games Management -->
      <div class="bg-white shadow-sm rounded-lg p-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Active Games</h2>

        <div id="games-loading" class="text-center py-8">
          <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600 mx-auto"></div>
          <p class="text-gray-600 mt-2">Loading your games...</p>
        </div>

        <div id="games-content" class="hidden">
          <div id="active-games-list" class="space-y-4">
            <!-- Games will be populated here -->
          </div>

          <div id="no-active-games" class="text-center py-8 hidden">
            <svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
            <h3 class="text-lg font-medium text-gray-900 mb-2">No Active Games</h3>
            <p class="text-gray-600 mb-4">You don't have any active games yet.</p>
            <a href={getPath('')} class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors">
              Start New Game
            </a>
          </div>
        </div>
      </div>

      <!-- Game Cleanup Section -->
      <div class="bg-white shadow-sm rounded-lg p-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Cleanup</h2>

        <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
          <h3 class="text-lg font-medium text-amber-800 mb-2">Delete Abandoned Games</h3>
          <p class="text-amber-700 text-sm mb-4">
            Remove games that you're no longer playing or that have been abandoned by other players.
            This will clean up your active games list and remove these games from your account.
          </p>
          <button
            id="cleanup-games-btn"
            class="px-4 py-2 bg-amber-600 text-white rounded-md hover:bg-amber-700 transition-colors"
          >
            Find & Delete Abandoned Games
          </button>
        </div>
      </div>

      <!-- Future Stats Section -->
      <div class="bg-white shadow-sm rounded-lg p-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Statistics</h2>

        <div class="text-center py-8 bg-gray-50 rounded-lg border-2 border-dashed border-gray-300">
          <svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          <h3 class="text-lg font-medium text-gray-900 mb-2">Coming Soon</h3>
          <p class="text-gray-600">
            Game statistics and performance analytics will be available here in a future update.
          </p>
        </div>
      </div>

      <!-- Danger Zone -->
      <div class="bg-white shadow-sm rounded-lg p-6 border-l-4 border-red-400">
        <h2 class="text-2xl font-bold text-red-900 mb-6">Danger Zone</h2>

        <div class="space-y-4">
          <p class="text-red-700">
            These actions cannot be undone. Please proceed with caution.
          </p>

          <button
            id="delete-account-btn"
            class="px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700 transition-colors"
          >
            Delete All Game Data
          </button>
          <p class="text-sm text-red-600">
            This will permanently delete all your game data, but will not delete your Google account.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Confirmation Modals -->
  <div id="confirm-cleanup-modal" class="fixed inset-0 bg-gray-900 bg-opacity-50 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-xl max-w-md w-full">
      <div class="p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Confirm Cleanup</h3>
        <p class="text-gray-600 mb-6">
          This will delete <span id="cleanup-count">0</span> abandoned game(s) from your account.
          This action cannot be undone.
        </p>
        <div class="flex space-x-3 justify-end">
          <button id="cancel-cleanup-btn" class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50">
            Cancel
          </button>
          <button id="confirm-cleanup-btn" class="px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700">
            Delete Games
          </button>
        </div>
      </div>
    </div>
  </div>

  <div id="confirm-delete-modal" class="fixed inset-0 bg-gray-900 bg-opacity-50 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-xl max-w-md w-full">
      <div class="p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Confirm Account Data Deletion</h3>
        <p class="text-gray-600 mb-6">
          This will permanently delete ALL your game data. Your Google account will remain intact,
          but all Pepper Scorer data will be lost forever. This action cannot be undone.
        </p>
        <div class="flex space-x-3 justify-end">
          <button id="cancel-delete-btn" class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50">
            Cancel
          </button>
          <button id="confirm-delete-btn" class="px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700">
            Delete All Data
          </button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
import { onAuthStateChange, getCurrentUser, getDisplayName, updateDisplayName, resetDisplayNameToGoogle } from '../lib/auth';
import { FirebaseGameManager } from '../lib/firebaseGameState';
import { subscribeToInvitations, acceptInvitation, declineInvitation } from '../lib/invitations';
import { getPath } from '../lib/path-utils';

let currentUser = null;
let authCheckTimeout = null;

// Show appropriate content based on auth state
function updateAuthState(user) {
  currentUser = user;
  const authLoading = document.getElementById('auth-loading');
  const authRequired = document.getElementById('auth-required');
  const accountContent = document.getElementById('account-content');

  // Clear any pending timeout
  if (authCheckTimeout) {
    clearTimeout(authCheckTimeout);
    authCheckTimeout = null;
  }

  if (user) {
    // User is authenticated - show account content immediately
    authLoading?.classList.add('hidden');
    authRequired?.classList.add('hidden');
    accountContent?.classList.remove('hidden');
    loadUserProfile(user);
    watchInvitations(user);
    loadActiveGames(user);
  } else {
    // User is not authenticated - show auth required after a brief delay
    stopWatchingInvitations();
    authLoading?.classList.add('hidden');
    accountContent?.classList.add('hidden');

    // Add a small delay to prevent flash if authentication resolves quickly
    authCheckTimeout = setTimeout(() => {
      authRequired?.classList.remove('hidden');
    }, 250);
  }
}

// Load and display user profile information
function loadUserProfile(user) {
  const profilePhoto = document.getElementById('profile-photo');
  const profileEmail = document.getElementById('profile-email');
  const profileUsername = document.getElementById('profile-username');
  const displayNameInput = document.getElementById('display-name-input');

  if (profilePhoto) {
    profilePhoto.src = user.photoURL || '/default-avatar.png';
    profilePhoto.alt = `${getDisplayName(user)}'s profile photo`;
  }

  if (profileEmail) {
    profileEmail.textContent = user.email || 'No email provided';
  }

  if (profileUsername) {
    profileUsername.textContent = user.username;
  }

  if (displayNameInput) {
    displayNameInput.value = user.displayName || '';
    // Enable save button when input changes
    displayNameInput.addEventListener('input', () => {
      const saveBtn = document.getElementById('save-display-name-btn');
      if (saveBtn) {
        saveBtn.disabled = displayNameInput.value === (user.displayName || '');
      }
    });
  }
}

// Live-subscribe to the user's pending invitations (Phase 9) so they appear/clear without a refresh.
let invitationsUnsub = null;
function watchInvitations(user) {
  if (invitationsUnsub) { invitationsUnsub(); invitationsUnsub = null; }
  invitationsUnsub = subscribeToInvitations(user.uid, (invitations) => renderInvitations(user, invitations));
}

function stopWatchingInvitations() {
  if (invitationsUnsub) { invitationsUnsub(); invitationsUnsub = null; }
  const card = document.getElementById('invitations-card');
  if (card) card.classList.add('hidden');
}

// Render the current pending-invitations list (called by the live listener on every change).
function renderInvitations(user, invitations) {
  const card = document.getElementById('invitations-card');
  const list = document.getElementById('invitations-list');
  if (!card || !list) return;

    if (!invitations.length) {
      card.classList.add('hidden');
      list.innerHTML = '';
      return;
    }

    card.classList.remove('hidden');
    list.innerHTML = '';

    invitations.forEach(inv => {
      const teamName = inv.teams?.[inv.teamIndex] || `Team ${inv.teamIndex + 1}`;
      const vs = `${inv.teams?.[0] ?? 'Team 1'} vs ${inv.teams?.[1] ?? 'Team 2'}`;

      const div = document.createElement('div');
      div.className = 'border border-amber-200 bg-amber-50 rounded-lg p-4';
      div.innerHTML = `
        <div class="flex justify-between items-start gap-3">
          <div class="min-w-0">
            <h3 class="font-medium text-amber-900 truncate">${inv.fromName} invited you to a game</h3>
            <p class="text-sm text-amber-700 truncate">${vs}</p>
            <p class="text-xs text-amber-600 mt-1 truncate">You're on ${teamName} with ${inv.partnerName}</p>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <button class="decline-invite px-3 py-1 bg-white text-amber-800 border border-amber-300 rounded text-sm hover:bg-amber-100 transition-colors">Decline</button>
            <button class="accept-invite px-3 py-1 bg-amber-600 text-white rounded text-sm hover:bg-amber-700 transition-colors">Accept</button>
          </div>
        </div>
        <p class="invite-error text-red-600 text-xs mt-2 hidden"></p>
      `;

      const acceptBtn = div.querySelector('.accept-invite');
      const declineBtn = div.querySelector('.decline-invite');
      const errorEl = div.querySelector('.invite-error');

      const runAction = async (action, label) => {
        acceptBtn.disabled = true;
        declineBtn.disabled = true;
        errorEl.classList.add('hidden');
        try {
          const ok = await action(inv.gameId);
          if (!ok) throw new Error('failed');
          // The invitations listener re-renders this list automatically once the node changes;
          // refresh active games so an accepted game shows up immediately.
          await loadActiveGames(user);
        } catch (e) {
          console.error(`Error on invite ${label}:`, e);
          acceptBtn.disabled = false;
          declineBtn.disabled = false;
          errorEl.textContent = 'Something went wrong. Please try again.';
          errorEl.classList.remove('hidden');
        }
      };

      acceptBtn.addEventListener('click', () => runAction(acceptInvitation, 'accept'));
      declineBtn.addEventListener('click', () => runAction(declineInvitation, 'decline'));

      list.appendChild(div);
    });
}

// Load active games for the user
async function loadActiveGames(user) {
  const gamesLoading = document.getElementById('games-loading');
  const gamesContent = document.getElementById('games-content');
  const activeGamesList = document.getElementById('active-games-list');
  const noActiveGames = document.getElementById('no-active-games');

  try {
    const activeGames = await FirebaseGameManager.getUserActiveGames(user.uid);

    gamesLoading?.classList.add('hidden');
    gamesContent?.classList.remove('hidden');

    if (activeGames.length === 0) {
      noActiveGames?.classList.remove('hidden');
      activeGamesList?.classList.add('hidden');
    } else {
      noActiveGames?.classList.add('hidden');
      activeGamesList?.classList.remove('hidden');

      if (activeGamesList) {
        activeGamesList.innerHTML = '';
        activeGames.forEach(game => {
          const gameElement = createGameElement(game);
          activeGamesList.appendChild(gameElement);
        });
      }
    }
  } catch (error) {
    console.error('Error loading active games:', error);
    gamesLoading?.classList.add('hidden');
    if (gamesContent) {
      gamesContent.innerHTML = `
        <div class="text-center py-8 text-red-600">
          <p>Error loading games. Please try again later.</p>
        </div>
      `;
      gamesContent.classList.remove('hidden');
    }
  }
}

// Create a game element for the games list
function createGameElement(game) {
  const div = document.createElement('div');
  div.className = 'border border-gray-200 rounded-lg p-4 hover:bg-gray-50 transition-colors';

  const createdAt = new Date(game.metadata.createdAt).toLocaleDateString();
  const lastUpdated = game.metadata.lastUpdated ?
    new Date(game.metadata.lastUpdated).toLocaleDateString() : 'Never';

  div.innerHTML = `
    <div class="flex justify-between items-start">
      <div class="flex-1">
        <h3 class="font-medium text-gray-900">${game.teams[0]} vs ${game.teams[1]}</h3>
        <p class="text-sm text-gray-600">Score: ${game.scores[0]} - ${game.scores[1]}</p>
        <p class="text-sm text-gray-600">Hands played: ${game.hands}</p>
        <div class="text-xs text-gray-500 mt-2">
          <p>Created: ${createdAt}</p>
          <p>Last updated: ${lastUpdated}</p>
        </div>
      </div>
      <div class="flex space-x-2">
        <button
          onclick="continueGame('${game.id}')"
          class="px-3 py-1 text-sm bg-blue-600 text-white rounded hover:bg-blue-700"
        >
          Continue
        </button>
        <button
          onclick="deleteGame('${game.id}')"
          class="px-3 py-1 text-sm bg-red-600 text-white rounded hover:bg-red-700"
        >
          Delete
        </button>
      </div>
    </div>
  `;

  return div;
}

// Global functions for game actions
window.continueGame = (gameId) => {
  window.location.href = getPath(`/game?id=${gameId}`);
};

window.deleteGame = async (gameId) => {
  if (confirm('Are you sure you want to delete this game? This action cannot be undone.')) {
    try {
      const success = await FirebaseGameManager.deleteGame(gameId);
      if (!success) {
        throw new Error('Failed to delete game');
      }

      // Reload games after deletion
      if (currentUser) {
        await loadActiveGames(currentUser);
      }
    } catch (error) {
      console.error('Error deleting game:', error);
      alert('Error deleting game. Please try again.');
    }
  }
};

// Event listeners
document.addEventListener('DOMContentLoaded', async () => {
  // Check authentication state

  // Set up auth state listener
  onAuthStateChange(updateAuthState);

  // Display name save button
  const saveDisplayNameBtn = document.getElementById('save-display-name-btn');
  saveDisplayNameBtn?.addEventListener('click', async () => {
    const input = document.getElementById('display-name-input');
    const newDisplayName = input?.value?.trim();

    if (!newDisplayName || !currentUser) return;

    try {
      saveDisplayNameBtn.disabled = true;
      saveDisplayNameBtn.textContent = 'Saving...';

      const updatedUser = await updateDisplayName(newDisplayName);
      if (!updatedUser) {
        throw new Error('Failed to update display name');
      }

      // Update the current user reference
      currentUser = updatedUser;

      saveDisplayNameBtn.textContent = 'Saved!';
      setTimeout(() => {
        saveDisplayNameBtn.textContent = 'Save';
        saveDisplayNameBtn.disabled = true;
      }, 2000);
    } catch (error) {
      console.error('Error updating display name:', error);
      alert('Error updating display name. Please try again.');
      saveDisplayNameBtn.disabled = false;
      saveDisplayNameBtn.textContent = 'Save';
    }
  });

  // Reset display name button
  const resetDisplayNameBtn = document.getElementById('reset-display-name-btn');
  resetDisplayNameBtn?.addEventListener('click', async () => {
    if (!currentUser) return;

    try {
      resetDisplayNameBtn.disabled = true;
      resetDisplayNameBtn.textContent = 'Resetting...';

      const updatedUser = await resetDisplayNameToGoogle();
      if (!updatedUser) {
        throw new Error('Failed to reset display name');
      }

      // Update the current user reference and form
      currentUser = updatedUser;
      const input = document.getElementById('display-name-input');
      if (input) {
        input.value = updatedUser.displayName || '';
      }

      // Update save button state
      const saveBtn = document.getElementById('save-display-name-btn');
      if (saveBtn) {
        saveBtn.disabled = true;
      }

      resetDisplayNameBtn.textContent = 'Reset!';
      setTimeout(() => {
        resetDisplayNameBtn.textContent = 'Reset to Google account name';
        resetDisplayNameBtn.disabled = false;
      }, 2000);
    } catch (error) {
      console.error('Error resetting display name:', error);
      alert('Error resetting display name. Please try again.');
      resetDisplayNameBtn.disabled = false;
      resetDisplayNameBtn.textContent = 'Reset to Google account name';
    }
  });

  // Cleanup games button
  const cleanupGamesBtn = document.getElementById('cleanup-games-btn');
  cleanupGamesBtn?.addEventListener('click', async () => {
    if (!currentUser) return;

    try {
      cleanupGamesBtn.disabled = true;
      cleanupGamesBtn.textContent = 'Searching...';

      const result = await FirebaseGameManager.cleanupAbandonedGames(currentUser.uid);

      // Show modal with actual count
      const modal = document.getElementById('confirm-cleanup-modal');
      const countSpan = document.getElementById('cleanup-count');
      if (countSpan) countSpan.textContent = result.count.toString();

      if (result.count === 0) {
        alert('No abandoned games found to clean up.');
      } else {
        modal?.classList.remove('hidden');
      }

      cleanupGamesBtn.disabled = false;
      cleanupGamesBtn.textContent = 'Find & Delete Abandoned Games';
    } catch (error) {
      console.error('Error finding abandoned games:', error);
      alert('Error finding abandoned games. Please try again.');
      cleanupGamesBtn.disabled = false;
      cleanupGamesBtn.textContent = 'Find & Delete Abandoned Games';
    }
  });

  // Delete account button
  const deleteAccountBtn = document.getElementById('delete-account-btn');
  deleteAccountBtn?.addEventListener('click', () => {
    const modal = document.getElementById('confirm-delete-modal');
    modal?.classList.remove('hidden');
  });

  // Modal event listeners
  const cancelCleanupBtn = document.getElementById('cancel-cleanup-btn');
  const confirmCleanupBtn = document.getElementById('confirm-cleanup-btn');
  const cancelDeleteBtn = document.getElementById('cancel-delete-btn');
  const confirmDeleteBtn = document.getElementById('confirm-delete-btn');

  cancelCleanupBtn?.addEventListener('click', () => {
    document.getElementById('confirm-cleanup-modal')?.classList.add('hidden');
  });

  confirmCleanupBtn?.addEventListener('click', async () => {
    if (!currentUser) return;

    try {
      confirmCleanupBtn.disabled = true;
      confirmCleanupBtn.textContent = 'Deleting...';

      const result = await FirebaseGameManager.cleanupAbandonedGames(currentUser.uid);

      document.getElementById('confirm-cleanup-modal')?.classList.add('hidden');

      if (result.count > 0) {
        alert(`Successfully deleted ${result.count} abandoned game(s).`);
        await loadActiveGames(currentUser);
      }

      confirmCleanupBtn.disabled = false;
      confirmCleanupBtn.textContent = 'Delete Games';
    } catch (error) {
      console.error('Error during cleanup:', error);
      alert('Error during cleanup. Please try again.');
      confirmCleanupBtn.disabled = false;
      confirmCleanupBtn.textContent = 'Delete Games';
    }
  });

  cancelDeleteBtn?.addEventListener('click', () => {
    document.getElementById('confirm-delete-modal')?.classList.add('hidden');
  });

  confirmDeleteBtn?.addEventListener('click', async () => {
    if (!currentUser) return;

    try {
      confirmDeleteBtn.disabled = true;
      confirmDeleteBtn.textContent = 'Deleting...';

      const success = await FirebaseGameManager.deleteAllUserData(currentUser.uid);

      if (success) {
        alert('All game data has been deleted successfully. You will now be redirected to the home page.');
        window.location.href = getPath('');
      } else {
        throw new Error('Failed to delete user data');
      }
    } catch (error) {
      console.error('Error deleting account data:', error);
      alert('Error deleting account data. Please try again.');
      confirmDeleteBtn.disabled = false;
      confirmDeleteBtn.textContent = 'Delete All Data';
      document.getElementById('confirm-delete-modal')?.classList.add('hidden');
    }
  });

  // Close modals when clicking outside
  document.getElementById('confirm-cleanup-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) {
      e.currentTarget.classList.add('hidden');
    }
  });

  document.getElementById('confirm-delete-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) {
      e.currentTarget.classList.add('hidden');
    }
  });
});
</script>