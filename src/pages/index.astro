window.diagnoseAuthDomain = async function() {
  console.log('=== AUTH DOMAIN DIAGNOSIS ===');
  try {
    const { firebaseConfig, isFirebaseConfigured } = await import('../lib/firebase');

    console.log('Firebase configured:', isFirebaseConfigured());
    console.log('Current URL details:', {
      href: window.location.href,
      origin: window.location.origin,
      hostname: window.location.hostname,
      protocol: window.location.protocol,
      port: window.location.port,
      pathname: window.location.pathname
    });

    console.log('Firebase config details:', {
      authDomain: firebaseConfig.authDomain,
      apiKey: firebaseConfig.apiKey?.substring(0, 10) + '...',
      projectId: firebaseConfig.projectId
    });

    // Check redirect URL configuration
    const authDomain = firebaseConfig.authDomain;
    const currentOrigin = window.location.origin;
    const currentHostname = window.location.hostname;
    const currentPath = window.location.pathname;
    const fullURL = currentOrigin + currentPath;
    const isDevelopment = currentOrigin.includes('localhost') || currentOrigin.includes('127.0.0.1');

    console.log('URL and domain analysis:', {
      authDomain,
      currentOrigin,
      currentHostname,
      currentPath,
      fullURL,
      isDevelopment,
      hostnameAuthorized: currentHostname === 'localhost' || authDomain?.includes(currentHostname)
    });

    // Check if this is the base path issue
    if (isDevelopment) {
      const hasBasePath = currentPath !== '/' && currentPath !== '';

      if (hasBasePath) {
        console.warn('🎯 POTENTIAL ISSUE: Base Path Configuration');
        console.warn('Current path:', currentPath);
        console.warn('Full URL:', fullURL);
        console.warn('');
        console.warn('Firebase will redirect back to this exact URL after authentication.');
        console.warn('If authentication fails, the issue might be:');
        console.warn('1. Astro base path configuration conflicts with Firebase redirects');
        console.warn('2. Firebase not handling the /pepper_scorer path correctly');
        console.warn('3. Need to test auth from root path (/) vs base path');
        console.warn('');
        console.warn('🧪 Try these tests:');
        console.warn('1. Test auth from http://localhost:4321/ (root)');
        console.warn('2. Test auth from http://localhost:4321/pepper_scorer/ (current)');
        console.warn('3. Check if Astro base path should be removed for development');
      } else {
        console.log('✅ Using root path - no base path conflicts');
      }

      // Check hostname authorization
      const hostnameAuthorized = currentHostname === 'localhost' || authDomain?.includes(currentHostname);
      if (!hostnameAuthorized) {
        console.error('🔴 HOSTNAME NOT AUTHORIZED');
        console.error('Add localhost to Firebase authorized domains');
      } else {
        console.log('✅ Hostname authorized in Firebase');
      }
    } else {
      console.log('ℹ️  Production environment detected');
    }

    // Check sessionStorage
    console.log('SessionStorage state:', {
      hasRedirectAttempt: !!sessionStorage.getItem('pepper_auth_redirect_attempt'),
      redirectAttemptTime: sessionStorage.getItem('pepper_auth_redirect_attempt'),
      redirectInfo: sessionStorage.getItem('pepper_auth_redirect_info'),
      allKeys: Object.keys(sessionStorage)
    });

    // Check localStorage
    console.log('LocalStorage state:', {
      hasCurrentGame: !!localStorage.getItem('currentGame'),
      allKeys: Object.keys(localStorage)
    });

  } catch (error) {
    console.error('Auth domain diagnosis failed:', error);
  }
  console.log('==============================');
};

