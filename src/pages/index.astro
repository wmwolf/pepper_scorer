---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import ResumeGameModal from '../components/resume-modal.astro';
---
<ResumeGameModal isVisible={false}/>
<BaseLayout title="New Game">
  <div class="max-w-3xl mx-auto">
    <!-- Cloud Connection Section -->
    <div id="auth-section" class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
      <div id="auth-logged-out" class="text-center">
        <p class="text-blue-700 mb-3"><strong>Pepper Scorer in the Cloud!</strong> Sign in to enable multiplayer features.</p>
        <div class="space-y-2">
          <button id="sign-in-btn" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors block w-full sm:w-auto sm:inline-block">
            Sign in with Google
          </button>
          <button id="skip-auth-btn" class="px-4 py-2 bg-gray-500 text-white rounded-md hover:bg-gray-600 transition-colors block w-full sm:w-auto sm:inline-block sm:ml-2 text-sm">
            Continue without signing in
          </button>
        </div>
        <p class="text-xs text-gray-600 mt-2">Note: Safari/DuckDuckGo users may experience auth issues. Consider using Chrome or continuing without signing in.</p>
      </div>

      <div id="auth-logged-in" class="hidden">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-3">
            <img id="user-photo" class="w-8 h-8 rounded-full" />
            <div>
              <p class="text-blue-800 font-medium">Welcome, <span id="user-name"></span>!</p>
              <p class="text-blue-600 text-sm">Username: <span id="user-username"></span></p>
            </div>
          </div>
          <button id="sign-out-btn" class="px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700 transition-colors text-sm">
            Sign Out
          </button>
        </div>

        <!-- Active Games Section -->
        <div id="active-games-section" class="mt-4 hidden">
          <h3 class="text-blue-800 font-medium mb-2">Your Active Games</h3>
          <div id="active-games-list" class="space-y-2">
            <!-- Active games will be populated here -->
          </div>
        </div>

        <!-- Join by Room Code (Phase 8) -->
        <div id="join-room-section" class="mt-4">
          <h3 class="text-blue-800 font-medium mb-2">Join a Game by Room Code</h3>
          <div class="flex flex-col sm:flex-row gap-2">
            <input
              id="room-code-input"
              type="text"
              inputmode="text"
              autocomplete="off"
              maxlength="6"
              placeholder="e.g. AB12CD"
              class="flex-1 px-3 py-2 border border-blue-200 rounded-md uppercase tracking-widest focus:outline-none focus:ring-2 focus:ring-blue-400"
            />
            <button id="join-room-btn" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors disabled:opacity-50">
              Join
            </button>
          </div>
          <p id="join-room-error" class="text-red-600 text-sm mt-1 hidden"></p>
        </div>
      </div>
    </div>

    <div class="bg-white shadow-sm rounded-lg p-6">
      <div class="space-y-6">
        
        <!-- Player Setup Form -->
        <div id="player-setup" class="space-y-6">
          <h2 class="text-2xl font-bold text-gray-900 text-center">
            Start a New Game
          </h2>
            <div class="bg-blue-50 border-l-4 border-blue-400 p-4 mb-6">
            <div class="flex">
              <div class="ml-3">
                <p class="text-sm text-blue-700">
                  Enter the names of the players in clockwise order, starting with the first dealer.
                </p>
              </div>
            </div>
          </div>
  
          <form id="player-form" class="space-y-4">
            <div class="space-y-4">
              {[1, 2, 3, 4].map(i => (
                <div class="space-y-2 relative">
                  <label
                    class="block text-sm font-medium text-gray-700"
                    for={`player-${i}`}
                  >
                    {i === 1 ? 'First Dealer' : `Player ${i}`}
                  </label>
                  <div class="relative">
                    <input
                      type="text"
                      id={`player-${i}`}
                      name={`player-${i}`}
                      class="block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 py-3 px-4 pr-12 text-base transition-all"
                      placeholder={`Enter player ${i} name or search registered users...`}
                      required
                      autocomplete="off"
                    />
                    <!-- User indicator (hidden by default) -->
                    <div id={`user-indicator-${i}`} class="hidden absolute right-3 top-1/2 transform -translate-y-1/2 flex items-center space-x-2">
                      <img id={`user-avatar-${i}`} class="w-6 h-6 rounded-full border border-gray-300" alt="User avatar" />
                      <div class="w-5 h-5 bg-green-500 rounded-full flex items-center justify-center">
                        <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                      </div>
                    </div>
                    <div id={`dropdown-${i}`} class="hidden absolute z-10 w-full mt-1 bg-white shadow-lg border border-gray-200 rounded-md max-h-40 overflow-y-auto">
                      <!-- Search results will appear here -->
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <p id="player-error" class="text-red-600 text-sm hidden"></p>

            <button
              type="submit"
              class="w-full rounded-md border border-transparent bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
            >
              Continue to Team Names
            </button>
          </form>
        </div>

        <!-- Team Setup Form (initially hidden) -->
        <div id="team-setup" class="space-y-6 hidden">
          <form id="team-form" class="space-y-6">
            <h2 class="text-2xl font-bold text-gray-900 text-center">
              Choose Team Names
            </h2>
              
            <div class="space-y-6">
              {[1, 2].map(i => (
                <div class="space-y-3">
                  <label 
                    class="block text-lg font-medium text-gray-800"
                    for={`team-${i}`}
                    id={`team-${i}-label`}
                  >
                    <!-- Will be filled by JS: "Player1 & Player3's Team" -->
                  </label>
                  <input
                    type="text"
                    id={`team-${i}`}
                    name={`team-${i}`}
                    class="block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 py-3 px-4 text-base transition-all"
                    placeholder="Enter team name"
                    required
                  />
                </div>
              ))}
            </div>

            <p class="text-sm text-gray-600 italic mt-2">
              Note: You can always convert a single game into a series after the game is complete.
            </p>

            <p id="team-error" class="text-red-600 text-sm hidden"></p>

            <div class="flex space-x-4 pt-2">
              <button
                type="button"
                id="back-to-players"
                class="flex-1 rounded-md border border-gray-300 bg-white px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
              >
                Back
              </button>
              <button
                type="submit"
                class="flex-1 rounded-md border border-transparent bg-blue-600 px-4 py-3 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
              >
                Start Game
              </button>
            </div>
          </form>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { GameManager } from '../lib/gameState';
  import { getPath } from '../lib/path-utils';
  import { signInWithGoogle, signInWithGoogleRedirect, completeRedirectSignIn, prefersRedirectSignIn, signOutUser, onAuthStateChange, getCurrentUser, searchUsers } from '../lib/auth';

  // Check for unfinished game on load
  document.addEventListener('DOMContentLoaded', async () => {
    // Initialize page

    try {
      // Check Firebase configuration first
      const { isFirebaseConfigured } = await import('../lib/firebase');

      if (isFirebaseConfigured()) {
        // Setup authentication
        setupAuth();
      }

      // Setup user autocomplete for player inputs
      setupUserAutocomplete();

      // Setup "join by room code" (Phase 8)
      setupJoinByRoomCode();

    } catch (error) {
      console.error('Error during initialization:', error);
    }

    // Check for unfinished game
    const savedGame = localStorage.getItem('currentGame');
    if (savedGame) {
      try {
        const gameData = JSON.parse(savedGame);
        const modal = document.getElementById('resume-modal');
        
        if (modal) {
          // Show the modal
          modal.classList.remove('opacity-0', 'pointer-events-none');
          // Populate the content
          if (window.populateModalContent) {
            window.populateModalContent(gameData);
          }
        }
      } catch (e) {
        console.error('Error parsing saved game:', e);
      }
    }
  });

  // State management
  const state = {
    players: ['', '', '', ''],
    teams: ['', ''],
    isSeries: false
  };


  // DOM Elements
  const playerForm = document.getElementById('player-form');
  const teamForm = document.getElementById('team-form');
  const playerSetup = document.getElementById('player-setup');
  const teamSetup = document.getElementById('team-setup');
  const backButton = document.getElementById('back-to-players');
  const playerError = document.getElementById('player-error');
  const teamError = document.getElementById('team-error');

  // Handle player form submission
  playerForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // Get player names
    state.players = [1, 2, 3, 4].map(i => {
      const input = document.getElementById(`player-${i}`) as HTMLInputElement;
      return input.value.trim();
    });

    // Validate
    if (state.players.some(name => !name)) {
      if (playerError) {
        playerError.textContent = 'All player names are required';
        playerError.classList.remove('hidden');
      }
      return;
    }

    // Update team labels with player names using ampersand format
    document.getElementById('team-1-label')!.textContent = 
      `${state.players[0]} & ${state.players[2]}'s Team`;
    document.getElementById('team-2-label')!.textContent = 
      `${state.players[1]} & ${state.players[3]}'s Team`;

    // Show team setup
    playerSetup?.classList.add('hidden');
    teamSetup?.classList.remove('hidden');
  });

  // Handle back button
  backButton?.addEventListener('click', () => {
    teamSetup?.classList.add('hidden');
    playerSetup?.classList.remove('hidden');
  });

  // Handle team form submission
teamForm?.addEventListener('submit', async (e) => {
  e.preventDefault();

  // Get team names
  state.teams = [1, 2].map(i => {
    const input = document.getElementById(`team-${i}`) as HTMLInputElement;
    return input.value.trim();
  });

  // Set series flag to false as we're removing the checkbox
  state.isSeries = false;

  // Validate
  if (state.teams.some(name => !name)) {
    if (teamError) {
      teamError.textContent = 'Both team names are required';
      teamError.classList.remove('hidden');
    }
    return;
  }

  try {
    // Get selected users data
    const selectedUsers = window.getSelectedUsers ? window.getSelectedUsers() : {};
    const hasRegisteredUsers = Object.values(selectedUsers).some(user => user?.isAuthenticated);

    let gameManager;

    if (hasRegisteredUsers) {
      // Import FirebaseGameManager for games with registered users
      const { FirebaseGameManager } = await import('../lib/firebaseGameState');
      const { getCurrentUser, isAuthenticated } = await import('../lib/auth');

      // Create players array with authentication data
      const playersData = state.players.map((playerName, index) => {
        const selectedUser = selectedUsers[index + 1];
        return {
          displayName: playerName,
          userId: selectedUser?.userId || null,
          username: selectedUser?.username || null,
          isAuthenticated: Boolean(selectedUser?.isAuthenticated),
          position: index
        };
      });

      // Get current user as game creator
      const currentUser = getCurrentUser();
      const createdBy = isAuthenticated() && currentUser ? currentUser.uid : null;

      // Create Firebase-enabled game
      gameManager = new FirebaseGameManager(state.players, state.teams);
      await gameManager.createFirebaseGame(playersData, createdBy);

          } else {
      // Use regular GameManager for manual-only games
      gameManager = new GameManager(state.players, state.teams);
          }

    // Save to localStorage (works for both Firebase and local games)
    localStorage.setItem('currentGame', gameManager.toJSON());

    // Navigate to game page
    window.location.href = getPath('/game');

  } catch (error) {
    console.error('Error creating game:', error);
    if (teamError) {
      teamError.textContent = 'Failed to create game. Please try again.';
      teamError.classList.remove('hidden');
    }
  }
});

// Authentication setup
function setupAuth() {
  // Setup authentication

  // Give DOM time to settle and try multiple times
  const setupAuthWithRetry = (attempt = 1) => {
    
    const signInBtn = document.getElementById('sign-in-btn');
    const signOutBtn = document.getElementById('sign-out-btn');
    const loggedOutSection = document.getElementById('auth-logged-out');
    const loggedInSection = document.getElementById('auth-logged-in');
    const userPhoto = document.getElementById('user-photo');
    const userName = document.getElementById('user-name');
    const userUsername = document.getElementById('user-username');

    
    if (!signInBtn && attempt < 5) {
            setTimeout(() => setupAuthWithRetry(attempt + 1), 100);
      return;
    }

    // Proceed with auth setup
    setupAuthHandlers(signInBtn, signOutBtn, loggedOutSection, loggedInSection, userPhoto, userName, userUsername);
  };

  setupAuthWithRetry();
}

// Separate function to set up auth handlers
function setupAuthHandlers(signInBtn, signOutBtn, loggedOutSection, loggedInSection, userPhoto, userName, userUsername) {
  // Update UI based on auth state
  function updateAuthUI(user) {
    if (user) {
      // User is signed in
      loggedOutSection?.classList.add('hidden');
      loggedInSection?.classList.remove('hidden');

      // Handle user photo with fallback and error handling
      if (userPhoto) {
        if (user.photoURL) {
          userPhoto.src = user.photoURL;
          userPhoto.style.display = 'block';

          // Add error handler for failed photo loads
          userPhoto.onerror = () => {
            console.warn('Failed to load user photo, using fallback');
            userPhoto.style.display = 'none';

            // Create or update fallback avatar with user's initials
            let fallbackAvatar = document.getElementById('fallback-avatar');
            if (!fallbackAvatar) {
              fallbackAvatar = document.createElement('div');
              fallbackAvatar.id = 'fallback-avatar';
              fallbackAvatar.className = 'w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-semibold text-sm';
              userPhoto.parentNode.insertBefore(fallbackAvatar, userPhoto);
            }

            // Use first letters of display name or username as initials
            const name = user.displayName || user.username || 'U';
            const initials = name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
            fallbackAvatar.textContent = initials;
            fallbackAvatar.style.display = 'flex';
          };
        } else {
          // No photo URL provided, show initials immediately
          userPhoto.style.display = 'none';

          let fallbackAvatar = document.getElementById('fallback-avatar');
          if (!fallbackAvatar) {
            fallbackAvatar = document.createElement('div');
            fallbackAvatar.id = 'fallback-avatar';
            fallbackAvatar.className = 'w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-semibold text-sm';
            userPhoto.parentNode.insertBefore(fallbackAvatar, userPhoto);
          }

          const name = user.displayName || user.username || 'U';
          const initials = name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
          fallbackAvatar.textContent = initials;
          fallbackAvatar.style.display = 'flex';
        }
      }

      if (userName) userName.textContent = user.displayName;
      if (userUsername) userUsername.textContent = user.username;

      // Load active games
      loadActiveGames(user);

          } else {
      // User is signed out
      loggedOutSection?.classList.remove('hidden');
      loggedInSection?.classList.add('hidden');

      // Clean up avatar elements
      if (userPhoto) {
        userPhoto.style.display = 'block';
        userPhoto.src = '';
        userPhoto.onerror = null;
      }

      // Remove fallback avatar if it exists
      const fallbackAvatar = document.getElementById('fallback-avatar');
      if (fallbackAvatar) {
        fallbackAvatar.remove();
      }

      // Hide active games section
      const activeGamesSection = document.getElementById('active-games-section');
      if (activeGamesSection) activeGamesSection.classList.add('hidden');

          }
  }

  // Set up auth state listener
  onAuthStateChange(updateAuthUI);

  // Complete a pending redirect sign-in (mobile flow returns here after Google). The auth-state
  // listener updates the UI once it resolves; getRedirectResult is a no-op when none is pending.
  completeRedirectSignIn().catch((err) => console.error('Redirect sign-in completion failed:', err));

  // Check current user on load
  const currentUser = getCurrentUser();
  if (currentUser) {
    updateAuthUI(currentUser);
  }

  // Sign in button
  if (signInBtn) {
    // Guard against overlapping sign-in attempts. Previously the button was bound THREE ways
    // (addEventListener + .onclick + a document-level click delegation), so a single tap fired
    // signInWithGoogle() multiple times and each new popup cancelled the previous one
    // (auth/cancelled-popup-request) — the "clunky, needs multiple attempts" behaviour.
    let signingIn = false;

    const handleSignIn = async (e) => {
      if (signingIn) { e?.preventDefault?.(); return; }
      signingIn = true;
      try {
        e.preventDefault(); // Prevent any default behavior
        e.stopPropagation(); // Stop event bubbling


        // Immediately show loading state
        signInBtn.disabled = true;
        signInBtn.textContent = 'Opening Google Sign-In...';

        // Hide the logged-out section and show a loading state
        if (loggedOutSection) {
          loggedOutSection.style.display = 'none';
        }

        // Show loading state in auth section
        const authSection = document.getElementById('auth-section');
        if (authSection) {
          const loadingDiv = document.createElement('div');
          loadingDiv.id = 'auth-loading';
          loadingDiv.className = 'text-center py-4';
          loadingDiv.innerHTML = `
            <div class="flex items-center justify-center space-x-2">
              <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-blue-600"></div>
              <span class="text-blue-700">Signing in with Google...</span>
            </div>
          `;
          authSection.appendChild(loadingDiv);
        }

        // Mobile (esp. iOS Safari) blocks the OAuth popup — use a full-page redirect. This
        // navigates away and returns to this page, where completeRedirectSignIn() (on load)
        // finishes the sign-in. Nothing after this runs (the page unloads).
        if (prefersRedirectSignIn()) {
          signInBtn.textContent = 'Redirecting to Google…';
          await signInWithGoogleRedirect();
          return;
        }

        const user = await signInWithGoogle();

        // Clean up loading state
        const loadingDiv = document.getElementById('auth-loading');
        if (loadingDiv) {
          loadingDiv.remove();
        }

        if (user) {
          // Success will be handled by the auth state change listener
          // No need to reset UI here - it will update automatically
        } else {
          // Sign-in was cancelled or failed — restore the original sign-in UI.
          if (loggedOutSection) {
            loggedOutSection.style.display = 'block';
          }
          signInBtn.disabled = false;
          signInBtn.textContent = 'Sign in with Google';
        }
      } catch (error) {
        console.error('Error signing in:', error);

        // Popup failed (blocked, COOP, etc.) — fall back to the redirect flow, which navigates
        // the whole page and is far more robust. This is the automatic recovery path.
        try {
          signInBtn.textContent = 'Redirecting to Google…';
          await signInWithGoogleRedirect();
          return;
        } catch (redirectError) {
          console.error('Redirect sign-in also failed:', redirectError);
          if (loggedOutSection) loggedOutSection.style.display = 'block';
          const loadingDiv = document.getElementById('auth-loading');
          if (loadingDiv) loadingDiv.remove();
          signInBtn.disabled = false;
          signInBtn.textContent = 'Sign in with Google';
          alert('Google sign-in failed. Please try again, or use another browser.');
        }
      } finally {
        // Allow a fresh attempt once this one settles (success transitions the UI via the auth
        // state listener; failure re-enables the button above).
        signingIn = false;
      }
    };

    // Bind the handler EXACTLY once. (Multiple bindings previously caused overlapping popups.)
    signInBtn.addEventListener('click', handleSignIn);

  } else {
    console.error('Sign-in button not found! Check DOM structure.');

    // Method 6: Last resort - event delegation without element reference
    document.addEventListener('click', (e) => {
      if (e.target && e.target.id === 'sign-in-btn') {
        // Try to find the button again
        const btn = document.getElementById('sign-in-btn');
        if (btn) {
          const handleSignIn = async (e) => {
            // Call signInWithGoogle directly for fallback
            try {
              const user = await signInWithGoogle();
            } catch (error) {
              console.error('Fallback sign-in error:', error);
            }
          };
          handleSignIn(e);
        }
      }
    });
  }

  // Sign out button
  signOutBtn?.addEventListener('click', async () => {
    try {
      await signOutUser();
    } catch (error) {
      console.error('Error signing out:', error);
    }
  });

  // Skip authentication button
  const skipAuthBtn = document.getElementById('skip-auth-btn');
  skipAuthBtn?.addEventListener('click', () => {

    // Hide the auth section to give the user a clean interface
    const authSection = document.getElementById('auth-section');
    if (authSection) {
      authSection.style.display = 'none';
    }

    // Show a brief confirmation
    const playerSetup = document.getElementById('player-setup');
    if (playerSetup) {
      const notice = document.createElement('div');
      notice.className = 'bg-yellow-50 border border-yellow-200 rounded-lg p-3 mb-4 text-center';
      notice.innerHTML = '<p class="text-yellow-700 text-sm">📱 <strong>Local Mode:</strong> Games will be saved on this device only.</p>';
      playerSetup.insertBefore(notice, playerSetup.firstChild);
    }
  });
}

// User autocomplete setup
function setupUserAutocomplete() {
  // Store selected user data for each player position
  const selectedUsers = {};
  let searchTimeout = null;

  // Setup autocomplete for each player input
  [1, 2, 3, 4].forEach(playerIndex => {
    const input = document.getElementById(`player-${playerIndex}`);
    const dropdown = document.getElementById(`dropdown-${playerIndex}`);

    if (!input || !dropdown) return;

    // Handle input changes with debouncing
    input.addEventListener('input', async (e) => {
      const query = e.target.value.trim();
      const userIndicator = document.getElementById(`user-indicator-${playerIndex}`);

      // Clear previous timeout
      if (searchTimeout) {
        clearTimeout(searchTimeout);
      }

      // Hide user indicator and clear selection when user types
      if (selectedUsers[playerIndex] && e.target.value !== selectedUsers[playerIndex].displayName) {
        selectedUsers[playerIndex] = null;
        userIndicator?.classList.add('hidden');
      }

      // Hide dropdown if query is too short
      if (query.length < 2) {
        dropdown.classList.add('hidden');
        selectedUsers[playerIndex] = null;
        userIndicator?.classList.add('hidden');
        return;
      }

      // Debounced search
      searchTimeout = setTimeout(async () => {
        try {
          const users = await searchUsers(query);
          displaySearchResults(dropdown, users, playerIndex, input);
        } catch (error) {
          console.error('Error searching users:', error);
        }
      }, 300);
    });

    // Handle focus/blur events
    input.addEventListener('focus', () => {
      if (input.value.length >= 2) {
        dropdown.classList.remove('hidden');
      }
    });

    input.addEventListener('blur', () => {
      // Delay hiding to allow clicking on dropdown items
      setTimeout(() => {
        dropdown.classList.add('hidden');
      }, 200);
    });
  });

  // Display search results in dropdown
  function displaySearchResults(dropdown, users, playerIndex, input) {
    if (users.length === 0) {
      dropdown.innerHTML = '<div class="px-3 py-2 text-gray-500 text-sm">No registered users found</div>';
      dropdown.classList.remove('hidden');
      return;
    }

    dropdown.innerHTML = users.map(user => `
      <div class="user-result px-3 py-2 hover:bg-blue-50 cursor-pointer flex items-center space-x-3"
           data-user-id="${user.uid}"
           data-username="${user.username}"
           data-display-name="${user.displayName}">
        <img src="${user.photoURL || '/default-avatar.png'}"
             alt="${user.displayName}"
             class="w-6 h-6 rounded-full"
             onerror="this.src='data:image/svg+xml;base64,'" />
        <div class="flex-1 min-w-0">
          <div class="text-sm font-medium text-gray-900 truncate">${user.displayName}</div>
          <div class="text-xs text-gray-500 truncate">@${user.username}</div>
        </div>
        <div class="text-xs text-blue-600">Registered</div>
      </div>
    `).join('');

    // Add click handlers
    dropdown.querySelectorAll('.user-result').forEach(item => {
      item.addEventListener('click', () => {
        const userId = item.dataset.userId;
        const username = item.dataset.username;
        const displayName = item.dataset.displayName;
        const photoURL = item.querySelector('img')?.src;

        // Store selected user data
        selectedUsers[playerIndex] = {
          userId,
          username,
          displayName,
          photoURL,
          isAuthenticated: true
        };

        // Update input value
        input.value = displayName;

        // Show user indicator
        const userIndicator = document.getElementById(`user-indicator-${playerIndex}`);
        const userAvatar = document.getElementById(`user-avatar-${playerIndex}`);

        if (userIndicator && userAvatar) {
          userAvatar.src = photoURL || 'data:image/svg+xml;base64,';
          userIndicator.classList.remove('hidden');
        }

        // Hide dropdown
        dropdown.classList.add('hidden');

      });
    });

    dropdown.classList.remove('hidden');
  }

  // Make selectedUsers accessible for game creation
  window.getSelectedUsers = () => selectedUsers;
}

// Join a game by its shareable room code (Phase 8).
function setupJoinByRoomCode() {
  const input = document.getElementById('room-code-input');
  const btn = document.getElementById('join-room-btn');
  const errorEl = document.getElementById('join-room-error');
  if (!input || !btn) return;

  const showError = (msg) => {
    if (errorEl) { errorEl.textContent = msg; errorEl.classList.remove('hidden'); }
  };
  const clearError = () => { if (errorEl) errorEl.classList.add('hidden'); };

  const join = async () => {
    const code = (input.value || '').trim().toUpperCase();
    clearError();
    if (code.length < 4) { showError('Enter a valid room code.'); return; }

    const originalLabel = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Joining…';
    try {
      const { isFirebaseConfigured } = await import('../lib/firebase');
      if (!isFirebaseConfigured()) { showError('Cloud play is not available right now.'); return; }

      const { FirebaseGameManager } = await import('../lib/firebaseGameState');
      const gameId = await FirebaseGameManager.findGameByRoomCode(code);
      if (!gameId) { showError('No game found with that room code.'); return; }

      window.location.href = getPath(`/game?id=${gameId}`);
    } catch (e) {
      console.error('Error joining by room code:', e);
      showError('Something went wrong. Please try again.');
    } finally {
      btn.disabled = false;
      btn.textContent = originalLabel;
    }
  };

  btn.addEventListener('click', join);
  input.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); join(); } });
  input.addEventListener('input', clearError);
}

// Load active games for signed-in user
async function loadActiveGames(user) {
  try {
    const { FirebaseGameManager } = await import('../lib/firebaseGameState');
    const activeGames = await FirebaseGameManager.getUserActiveGames(user.uid);

    const activeGamesSection = document.getElementById('active-games-section');
    const activeGamesList = document.getElementById('active-games-list');

    if (!activeGamesSection || !activeGamesList) {
      console.error('Active games UI elements not found');
      return;
    }

    if (activeGames.length === 0) {
      console.log('No active games found, hiding section');
      activeGamesSection.classList.add('hidden');
      return;
    }

    // Show the section
    activeGamesSection.classList.remove('hidden');

    // Clear existing content
    activeGamesList.innerHTML = '';

    // Add each active game
    activeGames.forEach(game => {
      const gameElement = document.createElement('div');
      gameElement.className = 'flex items-center justify-between p-3 bg-blue-50 border border-blue-200 rounded-md hover:bg-blue-100 transition-colors';

      const gameInfo = document.createElement('div');
      gameInfo.innerHTML = `
        <div class="font-medium text-blue-900">${game.teams[0]} vs ${game.teams[1]}</div>
        <div class="text-sm text-blue-600">Score: ${game.scores[0]} - ${game.scores[1]} • Hand ${game.hands + 1}</div>
        <div class="text-xs text-blue-500">Created ${new Date(game.metadata.createdAt).toLocaleDateString()}</div>
      `;

      const joinButton = document.createElement('button');
      joinButton.className = 'px-3 py-1 bg-blue-600 text-white rounded text-sm hover:bg-blue-700 transition-colors';
      joinButton.textContent = 'Join Game';
      joinButton.onclick = () => joinGame(game.id);

      gameElement.appendChild(gameInfo);
      gameElement.appendChild(joinButton);
      activeGamesList.appendChild(gameElement);
    });

  } catch (error) {
    console.error('Error loading active games:', error);
  }
}

// Join an existing game
function joinGame(gameId) {
  // Load the game into localStorage and navigate to it
  window.location.href = getPath(`/game?id=${gameId}`);
}

