// Debug function to inspect Firebase data directly
window.debugFirebaseData = async function(gameId) {
  try {
    const { getFirebaseDatabase, isFirebaseConfigured } = await import('../lib/firebase');

    if (!isFirebaseConfigured()) {
      console.log('Firebase not configured');
      return;
    }

    const database = getFirebaseDatabase();
    if (!database) {
      console.log('Database not available');
      return;
    }

    const { ref, get } = await import('firebase/database');

    if (gameId) {
      // Check specific game
      const gameRef = ref(database, `games/${gameId}`);
      const snapshot = await get(gameRef);

      if (snapshot.exists()) {
        const gameData = snapshot.val();
        console.log('=== FIREBASE GAME DATA ===');
        console.log('Game ID:', gameId);
        console.log('Full game data:', gameData);
        console.log('Game state specifically:', gameData.gameState);
        console.log('Current scores:', gameData.gameState?.scores);
        console.log('Hands array:', gameData.gameState?.hands);
        console.log('Hands count:', gameData.gameState?.hands?.length);
        console.log('=========================');
      } else {
        console.log('Game not found:', gameId);
      }
    } else {
      // Check all user games
      const { getCurrentUser } = await import('../lib/auth');
      const currentUser = getCurrentUser();

      if (!currentUser) {
        console.log('No current user');
        return;
      }

      const userGamesRef = ref(database, `userGames/${currentUser.uid}`);
      const userSnapshot = await get(userGamesRef);

      if (userSnapshot.exists()) {
        const gameIds = Object.keys(userSnapshot.val());
        console.log('=== USER GAMES DEBUG ===');
        console.log('User ID:', currentUser.uid);
        console.log('Game IDs:', gameIds);

        for (const gameId of gameIds) {
          const gameRef = ref(database, `games/${gameId}`);
          const gameSnapshot = await get(gameRef);

          if (gameSnapshot.exists()) {
            const gameData = gameSnapshot.val();
            console.log(`\n--- Game ${gameId} ---`);
            console.log('Teams:', gameData.teams);
            console.log('Status:', gameData.metadata?.status);
            console.log('Scores:', gameData.gameState?.scores);
            console.log('Hands:', gameData.gameState?.hands?.length || 0);
            console.log('Raw hands array:', gameData.gameState?.hands);
          }
        }
        console.log('======================');
      } else {
        console.log('No user games found');
      }
    }
  } catch (error) {
    console.error('Debug error:', error);
  }
};

