{
  "name": "pepper_scorer",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:emulator": "firebase emulators:exec --only auth,database --project demo-pepper \"vitest run --config vitest.emulator.config.ts\"",
    "dev:emulator": "firebase emulators:exec --only auth,database $([ -d ./emulator-data ] && echo --import=./emulator-data) --export-on-exit=./emulator-data \"PUBLIC_FIREBASE_EMULATOR=true ./node_modules/.bin/astro dev\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@astrojs/tailwind": "^5.1.4",
    "@sentry/browser": "^10.65.0",
    "astro": "^5.1.1",
    "astro-icon": "^1.1.5",
    "canvas-confetti": "^1.9.2",
    "firebase": "^12.6.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.2.4"
  }
}
