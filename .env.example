# Firebase configuration for Pepper Scorer.
#
# Copy this file to `.env` and fill in the values from your Firebase project:
#   Firebase console -> Project settings -> General -> "Your apps" -> SDK setup/config.
# All keys are exposed to the browser (Astro `PUBLIC_` prefix), which is expected
# for Firebase web config — access is controlled by Firebase Auth + database
# security rules, NOT by hiding these values.
#
# The app runs in local-only (localStorage) mode when Firebase is not configured,
# so these are optional for core scoring but required for auth + cloud sync.

# --- Required for Firebase to activate (see isFirebaseConfigured in src/lib/firebase.ts) ---
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# --- Used by the SDK but not required to enable Firebase ---
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Google Identity Services sign-in (fixes iOS Safari, which ITP-breaks popup/redirect) ---
# The OAuth 2.0 "Web client" ID from your Firebase project:
#   Firebase console -> Authentication -> Sign-in method -> Google -> Web SDK configuration
#   (or Google Cloud console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs).
# Add your app origins (e.g. https://billwolf.space and http://localhost:4321) to that client's
# "Authorized JavaScript origins". When unset, the app uses the popup/redirect flow instead.
PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# --- Error monitoring (optional; Sentry) ---
# Client-side error monitoring is entirely gated on this DSN: when unset, the Sentry SDK is never
# loaded and monitoring is a no-op (see src/lib/monitoring.ts). To enable, create a Sentry project
# (JavaScript / Browser), copy its DSN here, and add it as a GitHub Actions secret so the Pages
# build injects it. PUBLIC_SENTRY_RELEASE is an optional tag to group errors by deploy.
PUBLIC_SENTRY_DSN=
PUBLIC_SENTRY_RELEASE=
